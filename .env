# ============================================================
# BIXSO Agentic Educator - Environment Variables
# Copy this file to .env and fill in your actual keys.
# NEVER commit your real .env to version control.
# ============================================================

# ── LLM Provider ─────────────────────────────────────────────
# Set to "anthropic" to use Claude 3.5 Sonnet, or "openai" for GPT-4o-mini
LLM_PROVIDER=ollama
LLM_MODEL=llama3.2
OLLAMA_URL=http://localhost:11434

ANTHROPIC_API_KEY=""
OPENAI_API_KEY=""   # Required for embeddings regardless of LLM_PROVIDER
GOOGLE_API_KEY=""
# ── Database ──────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://namquang2017@localhost:5432/bixso_edu

# ── Qdrant Vector Store ───────────────────────────────────────
# Run locally: docker run -p 6333:6333 qdrant/qdrant
QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION=user_documents

# ── Embeddings (LangChain OpenAIEmbeddings) ───────────────────
EMBEDDING_MODEL=text-embedding-3-small
# ── RAG Chunking (LangChain RecursiveCharacterTextSplitter) ───
CHUNK_SIZE=512
CHUNK_OVERLAP=64
RAG_TOP_K=5

# ── Token Cost ────────────────────────────────────────────────
TOKEN_COST=5
