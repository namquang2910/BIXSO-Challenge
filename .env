#  LLM Provider 
LLM_PROVIDER=ollama
LLM_MODEL=llama3.2
OLLAMA_URL=http://localhost:11434

ANTHROPIC_API_KEY=""
OPENAI_API_KEY=""  
GOOGLE_API_KEY=""
#  Database 
DATABASE_URL=postgresql+asyncpg://namquang2017@localhost:5432/bixso_edu

#  Qdrant Vector Store 
