# ============================================================
# BIXSO Agentic Educator — Environment Variables
# Copy to .env and fill in your values. Never commit .env.
# ============================================================

# ── LLM Provider ─────────────────────────────────────────────
# Options: ollama | anthropic | openai | google
LLM_PROVIDER=ollama
LLM_MODEL=llama3.2

# Only required for LLM_PROVIDER=anthropic
ANTHROPIC_API_KEY=

# Only required for LLM_PROVIDER=openai
OPENAI_API_KEY=

# Only required for LLM_PROVIDER=google
GOOGLE_API_KEY=

# ── PostgreSQL ────────────────────────────────────────────────
# Inside Docker, DATABASE_URL is overridden by docker-compose.yml.
# Set this only for running the app outside Docker.
POSTGRES_USER=bixso
POSTGRES_PASSWORD=bixso_secret
POSTGRES_DB=bixso_edu
DATABASE_URL=postgresql+asyncpg://bixso:bixso_secret@localhost:5432/bixso_edu

# ── Qdrant ────────────────────────────────────────────────────
# Inside Docker this is overridden to http://qdrant:6333
QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION=user_documents

# ── Ollama ────────────────────────────────────────────────────
# Inside Docker this is overridden to http://ollama:11434
OLLAMA_URL=http://localhost:11434

# ── Embeddings ───────────────────────────────────────────────
# Uses local HuggingFace model — no API key needed.
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

# ── RAG Chunking ─────────────────────────────────────────────
CHUNK_SIZE=512
CHUNK_OVERLAP=64
RAG_TOP_K=5

# ── Token Cost ───────────────────────────────────────────────
TOKEN_COST=5
